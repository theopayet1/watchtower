# === Environnement ===
# dev  = replis silencieux actifs (tests en local)
# prod = échec BRUYANT si une config critique manque (à mettre dans la routine cloud)
APP_ENV=dev

# === Anthropic (étape 6) ===
# LOCAL : ANTHROPIC_API_KEY suffit.
# CLOUD (Claude Code web) : ce nom est réservé par la plateforme -> utilise plutôt
# VEILLE_ANTHROPIC_API_KEY (le code le lit en priorité, repli sur ANTHROPIC_API_KEY).
ANTHROPIC_API_KEY=
# VEILLE_ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# === Supabase (étape 5) ===
SUPABASE_URL=
SUPABASE_KEY=

# === Email ===
# Backend : auto | resend | brevo | smtp | file
#   - CLOUD (routine distante) : utilise resend ou brevo (API HTTPS 443).
#     Le SMTP (25/587) est souvent BLOQUÉ par la sandbox -> échec silencieux.
#   - LOCAL : SMTP marche très bien aussi.
EMAIL_BACKEND=auto

# Option A — API HTTP (recommandé cloud). Remplis UNE des deux.
RESEND_API_KEY=          # https://resend.com  (100 mails/j gratuits)
BREVO_API_KEY=           # https://www.brevo.com  (300 mails/j gratuits)

# Option B — SMTP (pratique en local). Ex. Outlook/Gmail + mot de passe d'application.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Expéditeur / destinataire (communs à tous les backends)
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
